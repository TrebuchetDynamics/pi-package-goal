# Dependencies
node_modules/

# Package-manager generated files
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build/test output
coverage/
.nyc_output/
dist/
*.tsbuildinfo
*.tgz

# Local environment and secrets
.env
.env.*
!.env.example

# Pi local runtime logs; project configs such as .pi/development-goal.json stay trackable.
.pi/*/logs.jsonl
.pi/*/logs-*.jsonl
# Smoke tests can accidentally run from subdirectories such as extensions/.
**/.pi/*/logs.jsonl
**/.pi/*/logs-*.jsonl

# OS/editor noise
.DS_Store
.vscode/
.idea/
*.swp
*~
